<style>
.site-header,#shopify-section-header,.site-footer,#shopify-section-footer,
[class*="header-wrapper"],[class*="footer-wrapper"],[class*="footer__"]{display:none!important}
body{background:#ffffff!important;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif!important;color:#0a1f3d!important;margin:0!important}

.vh{min-height:100vh;display:flex;flex-direction:column}

/* Annonce */
.vh-ann{background:linear-gradient(90deg,#0d3b8f,#1e5dc4,#0d3b8f);color:#fff!important;text-align:center;padding:8px 12px;font-size:12px;font-weight:700;letter-spacing:.3px}

/* Header noir */
.vh-bar{background:#0a0a0a;border-bottom:3px solid #1e5dc4;padding:14px 0;text-align:center}
.vh-bar .vh-logo{font-size:20px;font-weight:900;letter-spacing:2px;color:#fff!important;display:inline-flex;align-items:center;gap:6px}
.vh-bar .vh-logo::before{content:"▼";color:#1e5dc4!important;font-size:14px}
.vh-bar .vh-logo b{color:#1e5dc4!important;font-weight:400;font-size:11px;margin-left:6px;text-transform:uppercase;letter-spacing:1px}

/* HERO BANNER */
.vh-hero{background:linear-gradient(180deg,#fafbfc 0%,#eaf0fb 100%);padding:40px 20px 50px;text-align:center;position:relative;overflow:hidden}
.vh-hero::before{content:"";position:absolute;top:-30%;left:-10%;width:120%;height:80%;background:radial-gradient(ellipse at center,rgba(30,93,196,.08) 0%,transparent 60%);z-index:0;pointer-events:none}
.vh-hero-w{position:relative;z-index:1;max-width:1100px;margin:0 auto}
.vh-hero-tag{display:inline-block;background:#fff;border:1px solid #cdd9f0;color:#0d3b8f!important;font-size:11px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:6px 14px;border-radius:999px;margin-bottom:14px;box-shadow:0 2px 8px rgba(13,59,143,.06)}
.vh-hero-h{font-size:30px;font-weight:900;color:#0a1f3d!important;line-height:1.15;letter-spacing:-1px;margin:0 0 12px;max-width:680px;margin-left:auto;margin-right:auto}
.vh-hero-h span{color:#1e5dc4!important;background:linear-gradient(135deg,#0d3b8f,#1e5dc4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.vh-hero-sub{color:#5a6b85!important;font-size:15px;max-width:560px;margin:0 auto 28px;line-height:1.5}

/* Image hero personnalisée OU trio auto */
.vh-hero-img{display:block;width:100%;max-width:900px;margin:0 auto;height:auto;filter:drop-shadow(0 20px 40px rgba(13,59,143,.15));border-radius:16px}
.vh-trio{display:flex;justify-content:center;align-items:flex-end;gap:8px;max-width:780px;margin:0 auto;padding:0 10px}
.vh-trio-it{flex:1;min-width:0;text-align:center;position:relative;transition:transform .25s}
.vh-trio-it:hover{transform:translateY(-8px)}
.vh-trio-it img{width:100%;max-width:220px;height:auto;display:block;margin:0 auto;filter:drop-shadow(0 18px 32px rgba(13,59,143,.18))}
.vh-trio-it .vh-trio-bn{display:block;font-size:11px;font-weight:800;color:#0d3b8f!important;text-transform:uppercase;letter-spacing:.8px;margin-top:10px}
.vh-trio-mid{transform:scale(1.08);z-index:2}
.vh-trio-mid:hover{transform:scale(1.08) translateY(-8px)}
.vh-trio-placeholder{background:#fff;border:2px dashed #cdd9f0;border-radius:14px;aspect-ratio:1;display:flex;align-items:center;justify-content:center;color:#9ba8bf!important;font-size:11px;padding:14px;font-weight:600}

.vh-hero-cta{display:inline-block;margin-top:28px;background:linear-gradient(135deg,#0d3b8f,#1e5dc4);color:#fff!important;padding:14px 28px;border-radius:10px;font-weight:900;text-decoration:none;font-size:14px;text-transform:uppercase;letter-spacing:.8px;box-shadow:0 10px 28px rgba(13,59,143,.3)}

/* TRUST BAR */
.vh-trust-strip{background:#0a0a0a;padding:14px 20px}
.vh-trust-strip-w{max-width:1100px;margin:0 auto;display:flex;gap:14px;flex-wrap:wrap;justify-content:center;align-items:center}
.vh-trust-strip span{font-size:11px;color:#fff!important;font-weight:700;letter-spacing:.5px;display:inline-flex;align-items:center;gap:6px}
.vh-trust-strip span b{color:#1e5dc4!important;font-size:14px}

/* PRODUCTS GRID */
.vh-products{padding:50px 20px;background:#fff}
.vh-products-w{max-width:1100px;margin:0 auto}
.vh-products-h{font-size:26px;font-weight:900;color:#0a1f3d!important;text-align:center;margin:0 0 8px;letter-spacing:-.5px}
.vh-products-h span{color:#1e5dc4!important}
.vh-products-sub{text-align:center;color:#5a6b85!important;font-size:14px;margin:0 0 32px;max-width:520px;margin-left:auto;margin-right:auto}
.vh-grid{display:grid;grid-template-columns:1fr;gap:16px}
.vh-card{background:#fff;border:1px solid #d6def0;border-radius:14px;padding:24px;text-decoration:none;color:#0a1f3d!important;display:block;transition:border-color .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 12px rgba(13,59,143,.05);text-align:center}
.vh-card:hover{border-color:#1e5dc4;transform:translateY(-4px);box-shadow:0 14px 32px rgba(13,59,143,.14)}
.vh-card-img{width:100%;max-width:160px;height:160px;object-fit:contain;margin:0 auto 14px;display:block;filter:drop-shadow(0 12px 22px rgba(13,59,143,.12))}
.vh-card-h{font-size:18px;font-weight:900;color:#0a1f3d!important;margin:0 0 4px;letter-spacing:-.3px}
.vh-card-spec{color:#1e5dc4!important;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;margin:0 0 10px}
.vh-card-p{font-size:13px;color:#5a6b85!important;margin:0 0 16px;line-height:1.5}
.vh-card-cta{display:inline-block;background:linear-gradient(135deg,#0d3b8f,#1e5dc4);color:#fff!important;padding:10px 20px;border-radius:8px;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.5px;box-shadow:0 4px 12px rgba(13,59,143,.25)}

/* FOOTER */
.vh-ft{background:#0a0a0a;padding:24px 20px;text-align:center;color:#888!important;font-size:11px}
.vh-ft a{color:#1e5dc4!important;font-weight:600;text-decoration:none}

@media(min-width:768px){
  .vh-hero{padding:60px 20px 70px}
  .vh-hero-h{font-size:46px}
  .vh-hero-sub{font-size:17px}
  .vh-grid{grid-template-columns:repeat(3,1fr)}
  .vh-products-h{font-size:34px}
  .vh-trio-it img{max-width:260px}
}
@media(max-width:480px){
  .vh-trio{gap:4px}
  .vh-trio-it .vh-trio-bn{font-size:9px;letter-spacing:.3px}
}
</style>

{%- comment -%} Récupère les 3 produits pour le trio auto {%- endcomment -%}
{%- assign mg_product = all_products['magnesium'] -%}
{%- assign mo_product = all_products['moringa'] -%}
{%- assign bt_product = all_products['betterave'] -%}

<div class="vh">

  <div class="vh-ann">🇺🇸 MADE IN USA · 💰 PAIEMENT À LA LIVRAISON · 🛡️ GARANTIE 30 JOURS</div>

  <div class="vh-bar">
    <span class="vh-logo">VITALUX<b>NUTRITION</b></span>
  </div>

  <!-- HERO BANNER -->
  <section class="vh-hero">
    <div class="vh-hero-w">
      <span class="vh-hero-tag">Formulation Professionnelle</span>
      <h1 class="vh-hero-h">{{ settings.home_hero_title | default: 'La gamme Vitalux' }} <span>premium</span></h1>
      <p class="vh-hero-sub">{{ settings.home_hero_subtitle | default: '3 compléments naturels · Made in USA · Lab Tested · Non-GMO. Paiement à la livraison, garantie 30 jours.' }}</p>

      {%- if settings.home_hero_image != blank -%}
        {%- comment -%} Image hero personnalisée uploadée par l'admin {%- endcomment -%}
        <img class="vh-hero-img" src="{{ settings.home_hero_image | image_url: width: 1600 }}" alt="La gamme Vitalux Nutrition" width="1600" height="900" loading="eager" fetchpriority="high">
      {%- else -%}
        {%- comment -%} Trio auto : les 3 produits côte à côte {%- endcomment -%}
        <div class="vh-trio">
          <a class="vh-trio-it" href="/products/magnesium">
            {%- if mg_product.featured_image -%}
              <img src="{{ mg_product.featured_image | image_url: width: 500 }}" alt="Magnésium Vitalux" width="500" height="500" loading="eager">
            {%- else -%}
              <div class="vh-trio-placeholder">Ajouter image<br>Magnésium</div>
            {%- endif -%}
            <span class="vh-trio-bn">Magnésium</span>
          </a>
          <a class="vh-trio-it vh-trio-mid" href="/products/moringa">
            {%- if mo_product.featured_image -%}
              <img src="{{ mo_product.featured_image | image_url: width: 500 }}" alt="Moringa Vitalux" width="500" height="500" loading="eager">
            {%- else -%}
              <div class="vh-trio-placeholder">Ajouter image<br>Moringa</div>
            {%- endif -%}
            <span class="vh-trio-bn">Moringa</span>
          </a>
          <a class="vh-trio-it" href="/products/betterave">
            {%- if bt_product.featured_image -%}
              <img src="{{ bt_product.featured_image | image_url: width: 500 }}" alt="Betterave Vitalux" width="500" height="500" loading="eager">
            {%- else -%}
              <div class="vh-trio-placeholder">Ajouter image<br>Betterave</div>
            {%- endif -%}
            <span class="vh-trio-bn">Betterave</span>
          </a>
        </div>
      {%- endif -%}

      <a class="vh-hero-cta" href="#products">Découvrir la gamme ›</a>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <div class="vh-trust-strip">
    <div class="vh-trust-strip-w">
      <span><b>🇺🇸</b> Made in USA</span>
      <span><b>🔬</b> Lab Tested</span>
      <span><b>🏭</b> GMP Quality</span>
      <span><b>🌱</b> Non-GMO</span>
      <span><b>💰</b> Paiement à la livraison</span>
    </div>
  </div>

  <!-- PRODUCTS -->
  <section class="vh-products" id="products">
    <div class="vh-products-w">
      <h2 class="vh-products-h">Nos <span>3 compléments</span></h2>
      <p class="vh-products-sub">Chaque formule cible un besoin précis. Choisis celui qui te correspond.</p>

      <div class="vh-grid">
        <a class="vh-card" href="/products/magnesium">
          {%- if mg_product.featured_image -%}
            <img class="vh-card-img" src="{{ mg_product.featured_image | image_url: width: 400 }}" alt="Complexe de Magnésium" width="400" height="400" loading="lazy">
          {%- endif -%}
          <div class="vh-card-h">Complexe de Magnésium</div>
          <div class="vh-card-spec">8 formes · 2000 mg · 90 gélules</div>
          <p class="vh-card-p">Sommeil profond · Anti-stress · Muscles &amp; os · Bien-être général.</p>
          <span class="vh-card-cta">Découvrir ›</span>
        </a>
        <a class="vh-card" href="/products/moringa">
          {%- if mo_product.featured_image -%}
            <img class="vh-card-img" src="{{ mo_product.featured_image | image_url: width: 400 }}" alt="Moringa" width="400" height="400" loading="lazy">
          {%- endif -%}
          <div class="vh-card-h">Moringa Bio</div>
          <div class="vh-card-spec">92 nutriments · L'arbre de vie</div>
          <p class="vh-card-p">Énergie naturelle · Immunité · Peau &amp; cheveux · Vitalité globale.</p>
          <span class="vh-card-cta">Découvrir ›</span>
        </a>
        <a class="vh-card" href="/products/betterave">
          {%- if bt_product.featured_image -%}
            <img class="vh-card-img" src="{{ bt_product.featured_image | image_url: width: 400 }}" alt="Betterave" width="400" height="400" loading="lazy">
          {%- endif -%}
          <div class="vh-card-h">Betterave Concentrée</div>
          <div class="vh-card-spec">Extrait x10 · Sans sucre</div>
          <p class="vh-card-p">Tension régulée · Endurance +20% · Performance · Circulation.</p>
          <span class="vh-card-cta">Découvrir ›</span>
        </a>
      </div>
    </div>
  </section>

  <div class="vh-ft">
    © {{ 'now' | date: '%Y' }} VITALUX NUTRITION · Service client : <a href="tel:{{ settings.phone | replace: ' ', '' }}">{{ settings.phone | default: '+212 6 00 00 00 00' }}</a> · www.vitaluxnutrition.com
  </div>
</div>
