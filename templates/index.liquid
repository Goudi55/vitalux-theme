<script>
(function(){
  var track = document.getElementById('vx-track');
  var dots = document.querySelectorAll('.vx-dot');
  if(!track || !dots.length) return;
  dots.forEach(function(d){
    d.addEventListener('click', function(){
      var cards = track.querySelectorAll('.vx-tst-c');
      var i = parseInt(d.dataset.i, 10);
      if(cards[i]) track.scrollTo({left: cards[i].offsetLeft - 20, behavior:'smooth'});
    });
  });
  track.addEventListener('scroll', function(){
    var cards = track.querySelectorAll('.vx-tst-c');
    var cx = track.scrollLeft + track.offsetWidth / 2;
    var best = 0, bestD = Infinity;
    cards.forEach(function(c, i){
      var d = Math.abs(c.offsetLeft + c.offsetWidth / 2 - cx);
      if(d < bestD){ bestD = d; best = i; }
    });
    dots.forEach(function(d, i){ d.classList.toggle('on', i === best); });
  }, {passive:true});
})();
</script>
