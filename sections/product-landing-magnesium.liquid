<script>
(function(){
  // ─── Countdown 24h reset ───────────────────────────────────────
  function mgStartTimer(){
    var key = 'mg_deadline';
    var now = Date.now();
    var saved = localStorage.getItem(key);
    var deadline;
    if(saved && parseInt(saved,10) > now){
      deadline = parseInt(saved,10);
    } else {
      deadline = now + 24*60*60*1000;
      localStorage.setItem(key, deadline);
    }
    function tick(){
      var left = deadline - Date.now();
      if(left < 0){ left = 0; localStorage.removeItem(key); mgStartTimer(); return; }
      var h = Math.floor(left/3600000);
      var m = Math.floor((left%3600000)/60000);
      var s = Math.floor((left%60000)/1000);
      var str = (h<10?'0':'')+h+':'+(m<10?'0':'')+m+':'+(s<10?'0':'')+s;
      var t1 = document.getElementById('mg-timer');
      var t2 = document.getElementById('mg-timer2');
      var t3 = document.getElementById('mg-timer-hero');
      if(t1) t1.textContent = str;
      if(t2) t2.textContent = str;
      if(t3) t3.textContent = str;
    }
    tick();
    setInterval(tick, 1000);
  }
  mgStartTimer();

  // ─── Sticky bar ────────────────────────────────────────────────
  var sticky = document.getElementById('mg-sticky');
  if(sticky){
    window.addEventListener('scroll', function(){
      var hero = document.querySelector('.mg-hero');
      if(hero && window.innerWidth < 768 && hero.getBoundingClientRect().bottom < 0){
        sticky.classList.add('show');
      } else {
        sticky.classList.remove('show');
      }
    }, {passive:true});
  }

  // ─── Carousel ──────────────────────────────────────────────────
  var slider = document.getElementById('mg-slider');
  var slides = slider ? slider.querySelectorAll('.mg-slide') : [];
  var dots = document.querySelectorAll('.mg-dot');
  var thumbs = document.querySelectorAll('.mg-thumb');
  var current = 0, autoTimer = null;
  function show(i){
    if(!slides.length) return;
    i = ((i%slides.length)+slides.length)%slides.length;
    current = i;
    slides.forEach(function(s,idx){s.classList.toggle('active',idx===i)});
    dots.forEach(function(d,idx){d.classList.toggle('active',idx===i)});
    thumbs.forEach(function(t,idx){t.classList.toggle('active',idx===i)});
  }
  function start(){ stop(); if(slides.length>1) autoTimer=setInterval(function(){show(current+1)},4000); }
  function stop(){ if(autoTimer){clearInterval(autoTimer);autoTimer=null;} }
  window.mgGo = function(i){show(i);start()};
  dots.forEach(function(d){d.addEventListener('click',function(){show(parseInt(d.dataset.idx,10));start()})});
  if(slider && slides.length>1){
    var sx=0,sy=0,mv=false;
    slider.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;sy=e.touches[0].clientY;mv=false;stop()},{passive:true});
    slider.addEventListener('touchmove',function(e){if(Math.abs(e.touches[0].clientX-sx)>10)mv=true},{passive:true});
    slider.addEventListener('touchend',function(e){
      var dx=e.changedTouches[0].clientX-sx,dy=e.changedTouches[0].clientY-sy;
      if(mv&&Math.abs(dx)>40&&Math.abs(dx)>Math.abs(dy)){show(current+(dx<0?1:-1));}
      start();
    },{passive:true});
    document.addEventListener('visibilitychange',function(){if(document.hidden)stop();else start();});
    start();
  }


})();
</script>

